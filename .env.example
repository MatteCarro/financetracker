# Cloud sync (Supabase) — opzionale.
# Senza queste variabili l'app funziona 100% in locale; il sync è disattivato.
# Copia in .env (sviluppo) e impostale anche su Vercel (Project → Settings → Environment Variables).

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...la-tua-anon-key
